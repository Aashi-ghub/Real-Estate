generator client {
  provider = "prisma-client-js"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ClientStatus {
  active
  paused
}

enum WhatsAppProvider {
  twilio
  meta
}

enum CrmType {
  zoho
  hubspot
  custom
}

enum LeadStatus {
  new
  contacted
  qualified
  visit_booked
  closed
  lost
}

enum LeadAttributeKey {
  budget
  location
  timeline
  property_type
  purpose
  financing_needed
}

enum ConversationChannel {
  whatsapp
}

enum ConversationState {
  INIT
  ASK_BUDGET
  ASK_LOCATION
  ASK_TIMELINE
  ASK_PURPOSE
  QUALIFIED
}

enum MessageDirection {
  inbound
  outbound
}

enum MessageStatus {
  queued
  sent
  delivered
  failed
}

enum ApiKeyStatus {
  active
  revoked
}

enum UserStatus {
  active
  disabled
}

enum RoleName {
  SUPER_ADMIN
  TENANT_ADMIN
  AGENT
  VIEWER
}

enum RefreshSessionStatus {
  active
  revoked
  expired
}

enum AuditEventSeverity {
  info
  warn
  error
}

enum TenantUsageMetric {
  leads
  api_requests
  webhooks
  queue_jobs
}

enum QuotaEventType {
  warning
  exceeded
  enforced
}

enum JobStatus {
  queued
  processing
  completed
  failed
  dead_letter
}

enum CrmSyncStatus {
  pending
  processing
  success
  failed
}

enum LeadPriority {
  HOT
  WARM
  COLD
}

enum FollowUpTrigger {
  no_reply
  incomplete_qualification
  warm_lead_reengagement
  revisit_reminder
}

enum FollowUpStatus {
  scheduled
  sent
  cancelled
  skipped
  failed
}

model Client {
  id               String      @id @default(uuid()) @db.Uuid
  name             String      @db.VarChar(120)
  status           ClientStatus
  timezone         String      @db.VarChar(64)
  whatsappProvider WhatsAppProvider
  whatsappConfig   Json
  crmType          CrmType
  crmConfig        Json
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  apiKeys   ApiKey[]
  leads     Lead[]
  jobs      Job[]
  auditLogs AuditLog[]
  crmSyncs  CrmSync[]
  users     User[]
  auditEvents AuditEvent[]
  billingPeriods BillingPeriod[]
  tenantUsages TenantUsage[]
  rateLimitBuckets RateLimitBucket[]
  workerHeartbeats WorkerHeartbeat[]

  @@index([status])
}

model ApiKey {
  id         String       @id @default(uuid()) @db.Uuid
  clientId   String       @db.Uuid
  name       String       @db.VarChar(120)
  hashedKey  String       @unique @db.VarChar(128)
  prefix     String?      @unique @db.VarChar(24)
  scopes     String[]     @default([])
  expiresAt  DateTime?
  revokedAt  DateTime?
  usageCount Int          @default(0)
  status     ApiKeyStatus @default(active)
  lastUsedAt DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, status])
  @@index([clientId, prefix])
  @@index([clientId, expiresAt])
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  clientId     String?    @db.Uuid
  email        String     @unique @db.VarChar(255)
  passwordHash String     @db.VarChar(255)
  status       UserStatus @default(active)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  client Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)
  roles UserRole[]
  refreshSessions RefreshSession[]

  @@index([clientId, status])
  @@index([email, status])
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        RoleName @unique
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now())

  permissions RolePermission[]
  users UserRole[]
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique @db.VarChar(120)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now())

  roles RolePermission[]
}

model UserRole {
  userId String @db.Uuid
  roleId String @db.Uuid
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

model RolePermission {
  roleId String @db.Uuid
  permissionId String @db.Uuid
  createdAt DateTime @default(now())

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model RefreshSession {
  id         String               @id @default(uuid()) @db.Uuid
  userId     String               @db.Uuid
  tokenHash  String               @unique @db.VarChar(128)
  status     RefreshSessionStatus @default(active)
  userAgent  String?              @db.VarChar(255)
  ipAddress  String?              @db.VarChar(64)
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([expiresAt])
}

model Lead {
  id             String     @id @default(uuid()) @db.Uuid
  clientId       String     @db.Uuid
  name           String     @db.VarChar(160)
  phone          String     @db.VarChar(32)
  email          String?    @db.VarChar(255)
  source         String     @db.VarChar(100)
  status         LeadStatus @default(new)
  score          Int        @default(0)
  priority       LeadPriority @default(COLD)
  qualificationCompleteness Int @default(0)
  intentConfidence Float    @default(0)
  crmSyncStatus CrmSyncStatus?
  crmExternalId String?    @db.VarChar(128)
  crmLastSyncAt DateTime?
  crmErrorLogs  Json?
  idempotencyKey String     @unique @db.VarChar(255)
  metadata       Json?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  client       Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  attributes   LeadAttribute[]
  conversation Conversation?
  jobs         Job[]
  crmSyncs     CrmSync[]
  scores       LeadScore[]
  followUps    FollowUp[]
  crmSyncLogs  CrmSyncLog[]

  @@index([phone])
  @@index([clientId, phone])
  @@index([clientId, status])
  @@index([clientId, status, createdAt])
  @@index([clientId, status, updatedAt])
  @@index([clientId, priority, score])
  @@index([clientId, priority, createdAt])
  @@index([clientId, crmSyncStatus])
  @@index([clientId, qualificationCompleteness])
  @@index([clientId, qualificationCompleteness, createdAt])
  @@index([clientId, createdAt])
  @@index([clientId, updatedAt])
  @@index([clientId, score])
  @@index([clientId, source, createdAt])
}

model LeadAttribute {
  id        String           @id @default(uuid()) @db.Uuid
  leadId    String           @db.Uuid
  key       LeadAttributeKey
  value     Json
  rawValue  String?          @db.Text
  confidence Float           @default(1)
  source    String           @default("rule") @db.VarChar(40)
  metadata  Json?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([leadId, key])
  @@index([leadId])
}

model LeadScore {
  id        String       @id @default(uuid()) @db.Uuid
  leadId    String       @db.Uuid
  clientId  String       @db.Uuid
  total     Int
  priority  LeadPriority
  breakdown Json
  version   String       @db.VarChar(40)
  createdAt DateTime     @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([clientId, total])
  @@index([leadId, createdAt])
}

model Conversation {
  id            String              @id @default(uuid()) @db.Uuid
  leadId        String              @unique @db.Uuid
  channel       ConversationChannel
  state         ConversationState   @default(INIT)
  context       Json                @default("{}")
  lastMessageAt DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  lead     Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([state, lastMessageAt])
}

model Message {
  id                String           @id @default(uuid()) @db.Uuid
  conversationId    String           @db.Uuid
  direction         MessageDirection
  content           String           @db.Text
  providerMessageId String?          @unique @db.VarChar(120)
  dedupeKey         String?          @unique @db.VarChar(255)
  status            MessageStatus    @default(queued)
  metadata          Json?
  createdAt         DateTime         @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([conversationId, createdAt])
  @@index([conversationId, direction, createdAt])
}

model Job {
  id             String    @id @default(uuid()) @db.Uuid
  clientId       String    @db.Uuid
  leadId         String?   @db.Uuid
  queue          String    @db.VarChar(64)
  name           String    @db.VarChar(64)
  idempotencyKey String    @unique @db.VarChar(255)
  requestId      String?   @db.VarChar(128)
  correlationId  String?   @db.VarChar(128)
  status         JobStatus @default(queued)
  attempts       Int       @default(0)
  payload        Json
  metadata       Json?
  scheduledAt    DateTime?
  processedAt    DateTime?
  lastError      String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lead   Lead?  @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([clientId, queue, status])
  @@index([leadId, name])
  @@index([requestId, correlationId])
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  clientId  String?  @db.Uuid
  actor     String   @db.VarChar(120)
  action    String   @db.VarChar(120)
  entity    String   @db.VarChar(120)
  entityId  String   @db.VarChar(64)
  requestId String?  @db.VarChar(128)
  correlationId String? @db.VarChar(128)
  metadata  Json
  createdAt DateTime @default(now())

  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([clientId, createdAt])
  @@index([entity, entityId, createdAt])
  @@index([requestId, correlationId, createdAt])
}

model AuditEvent {
  id            String             @id @default(uuid()) @db.Uuid
  clientId      String?            @db.Uuid
  actorType     String             @db.VarChar(40)
  actorId       String?            @db.VarChar(120)
  action        String             @db.VarChar(120)
  entity        String             @db.VarChar(120)
  entityId      String?            @db.VarChar(120)
  requestId     String?            @db.VarChar(128)
  correlationId String?            @db.VarChar(128)
  ipAddress     String?            @db.VarChar(64)
  userAgent     String?            @db.VarChar(255)
  severity      AuditEventSeverity @default(info)
  metadata      Json               @default("{}")
  createdAt     DateTime           @default(now())

  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([clientId, createdAt])
  @@index([clientId, action, createdAt])
  @@index([entity, entityId, createdAt])
  @@index([requestId, correlationId, createdAt])
}

model BillingPeriod {
  id        String   @id @default(uuid()) @db.Uuid
  clientId  String   @db.Uuid
  startsAt  DateTime
  endsAt    DateTime
  planKey   String   @db.VarChar(80)
  quotas    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  usage TenantUsage[]

  @@unique([clientId, startsAt, endsAt])
  @@index([clientId, startsAt, endsAt])
}

model TenantUsage {
  id              String            @id @default(uuid()) @db.Uuid
  clientId        String            @db.Uuid
  billingPeriodId String            @db.Uuid
  metric          TenantUsageMetric
  used            Int               @default(0)
  limit           Int
  warnedAt        DateTime?
  exceededAt      DateTime?
  updatedAt       DateTime          @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  billingPeriod BillingPeriod @relation(fields: [billingPeriodId], references: [id], onDelete: Cascade)

  @@unique([clientId, billingPeriodId, metric])
  @@index([clientId, metric])
}

model QuotaEvent {
  id              String          @id @default(uuid()) @db.Uuid
  clientId        String          @db.Uuid
  billingPeriodId String          @db.Uuid
  metric          TenantUsageMetric
  eventType       QuotaEventType
  usageValue      Int
  limitValue      Int
  requestId       String?         @db.VarChar(128)
  metadata        Json            @default("{}")
  createdAt       DateTime        @default(now())

  @@index([clientId, metric, createdAt])
  @@index([billingPeriodId, createdAt])
}

model RateLimitBucket {
  id        String   @id @default(uuid()) @db.Uuid
  clientId  String?  @db.Uuid
  subject   String   @db.VarChar(180)
  windowKey String   @db.VarChar(80)
  count     Int      @default(0)
  expiresAt DateTime
  updatedAt DateTime @updatedAt

  client Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([subject, windowKey])
  @@index([clientId, expiresAt])
  @@index([expiresAt])
}

model WorkerHeartbeat {
  id          String   @id @default(uuid()) @db.Uuid
  clientId    String?  @db.Uuid
  workerName  String   @db.VarChar(120)
  queueName   String   @db.VarChar(64)
  processId   Int
  hostname    String   @db.VarChar(120)
  status      String   @db.VarChar(40)
  lastBeatAt  DateTime
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@unique([workerName, queueName, processId, hostname])
  @@index([queueName, status, lastBeatAt])
  @@index([clientId, lastBeatAt])
}

model CrmSync {
  id             String        @id @default(uuid()) @db.Uuid
  clientId       String        @db.Uuid
  leadId         String        @db.Uuid
  idempotencyKey String        @unique @db.VarChar(255)
  status         CrmSyncStatus @default(pending)
  requestPayload Json
  responsePayload Json?
  externalId     String?       @db.VarChar(128)
  attempts       Int           @default(0)
  lastError      String?       @db.Text
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([clientId, leadId, status])
}

model CrmSyncLog {
  id             String        @id @default(uuid()) @db.Uuid
  clientId       String        @db.Uuid
  leadId         String        @db.Uuid
  crmSyncId      String?       @db.Uuid
  idempotencyKey String        @db.VarChar(255)
  status         CrmSyncStatus
  provider       CrmType
  externalId     String?       @db.VarChar(128)
  error          String?       @db.Text
  metadata       Json?
  createdAt      DateTime      @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([clientId, leadId, createdAt])
  @@index([idempotencyKey])
}

model FollowUp {
  id             String          @id @default(uuid()) @db.Uuid
  clientId       String          @db.Uuid
  leadId         String          @db.Uuid
  conversationId String          @db.Uuid
  trigger        FollowUpTrigger
  status         FollowUpStatus  @default(scheduled)
  dedupeKey      String          @unique @db.VarChar(255)
  scheduledAt    DateTime
  sentAt         DateTime?
  cancelledAt    DateTime?
  metadata       Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([clientId, status, scheduledAt])
  @@index([clientId, scheduledAt])
  @@index([leadId, status])
  @@index([conversationId, trigger])
}
