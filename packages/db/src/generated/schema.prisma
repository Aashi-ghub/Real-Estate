generator client {
  provider = "prisma-client-js"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ClientStatus {
  active
  paused
}

enum WhatsAppProvider {
  twilio
  meta
}

enum CrmType {
  zoho
  hubspot
  custom
}

enum LeadStatus {
  new
  contacted
  qualified
  visit_booked
  closed
  lost
}

enum LeadAttributeKey {
  budget
  location
  timeline
  purpose
}

enum ConversationChannel {
  whatsapp
}

enum ConversationState {
  INIT
  ASK_BUDGET
  ASK_LOCATION
  ASK_TIMELINE
  ASK_PURPOSE
  QUALIFIED
}

enum MessageDirection {
  inbound
  outbound
}

enum MessageStatus {
  queued
  sent
  delivered
  failed
}

enum ApiKeyStatus {
  active
  revoked
}

enum JobStatus {
  queued
  processing
  completed
  failed
  dead_letter
}

enum CrmSyncStatus {
  pending
  processing
  success
  failed
}

model Client {
  id               String           @id @default(uuid()) @db.Uuid
  name             String           @db.VarChar(120)
  status           ClientStatus
  timezone         String           @db.VarChar(64)
  whatsappProvider WhatsAppProvider
  whatsappConfig   Json
  crmType          CrmType
  crmConfig        Json
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  apiKeys   ApiKey[]
  leads     Lead[]
  jobs      Job[]
  auditLogs AuditLog[]
  crmSyncs  CrmSync[]

  @@index([status])
}

model ApiKey {
  id         String       @id @default(uuid()) @db.Uuid
  clientId   String       @db.Uuid
  name       String       @db.VarChar(120)
  hashedKey  String       @unique @db.VarChar(128)
  status     ApiKeyStatus @default(active)
  lastUsedAt DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, status])
}

model Lead {
  id             String     @id @default(uuid()) @db.Uuid
  clientId       String     @db.Uuid
  name           String     @db.VarChar(160)
  phone          String     @db.VarChar(32)
  email          String?    @db.VarChar(255)
  source         String     @db.VarChar(100)
  status         LeadStatus @default(new)
  score          Int        @default(0)
  idempotencyKey String     @unique @db.VarChar(255)
  metadata       Json?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  client       Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  attributes   LeadAttribute[]
  conversation Conversation?
  jobs         Job[]
  crmSyncs     CrmSync[]

  @@index([phone])
  @@index([clientId, phone])
  @@index([clientId, status])
  @@index([clientId, createdAt])
}

model LeadAttribute {
  id        String           @id @default(uuid()) @db.Uuid
  leadId    String           @db.Uuid
  key       LeadAttributeKey
  value     Json
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([leadId, key])
  @@index([leadId])
}

model Conversation {
  id            String              @id @default(uuid()) @db.Uuid
  leadId        String              @unique @db.Uuid
  channel       ConversationChannel
  state         ConversationState   @default(INIT)
  context       Json                @default("{}")
  lastMessageAt DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  lead     Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([state, lastMessageAt])
}

model Message {
  id                String           @id @default(uuid()) @db.Uuid
  conversationId    String           @db.Uuid
  direction         MessageDirection
  content           String           @db.Text
  providerMessageId String?          @unique @db.VarChar(120)
  dedupeKey         String?          @unique @db.VarChar(255)
  status            MessageStatus    @default(queued)
  metadata          Json?
  createdAt         DateTime         @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([conversationId, createdAt])
}

model Job {
  id             String    @id @default(uuid()) @db.Uuid
  clientId       String    @db.Uuid
  leadId         String?   @db.Uuid
  queue          String    @db.VarChar(64)
  name           String    @db.VarChar(64)
  idempotencyKey String    @unique @db.VarChar(255)
  status         JobStatus @default(queued)
  attempts       Int       @default(0)
  payload        Json
  scheduledAt    DateTime?
  processedAt    DateTime?
  lastError      String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lead   Lead?  @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([clientId, queue, status])
  @@index([leadId, name])
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  clientId  String?  @db.Uuid
  actor     String   @db.VarChar(120)
  action    String   @db.VarChar(120)
  entity    String   @db.VarChar(120)
  entityId  String   @db.VarChar(64)
  metadata  Json
  createdAt DateTime @default(now())

  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([clientId, createdAt])
  @@index([entity, entityId, createdAt])
}

model CrmSync {
  id              String        @id @default(uuid()) @db.Uuid
  clientId        String        @db.Uuid
  leadId          String        @db.Uuid
  idempotencyKey  String        @unique @db.VarChar(255)
  status          CrmSyncStatus @default(pending)
  requestPayload  Json
  responsePayload Json?
  externalId      String?       @db.VarChar(128)
  attempts        Int           @default(0)
  lastError       String?       @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([clientId, leadId, status])
}
